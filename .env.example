# Django Settings
SECRET_KEY=django-insecure-mude-me-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
INTERNAL_IPS=127.0.0.1

# Database configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jrm_dev

# Security (Production only)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_NAME=jrm_dev
SESSION_COOKIE_AGE=21600
SESSION_SAVE_EVERY_REQUEST=True
SESSION_COOKIE_HTTPONLY=True

# HSTS
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging
DJANGO_LOG_LEVEL=INFO

# AWS S3 Storage (for DEBUG=False production settings)
# AWS_ACCESS_KEY_ID=sua-chave-aqui
# AWS_SECRET_ACCESS_KEY=seu-segredo-aqui
# AWS_STORAGE_BUCKET_NAME=seu-bucket-aqui
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=https://s3.amazonaws.com
# AWS_S3_CUSTOM_DOMAIN=cdn.seu-dominio.com

